# ── 9toFit scanner — environment variables ──

# URL van het platform dat /api/scan-submit host (default app.9tofit.nl)
NEXT_PUBLIC_PLATFORM_URL=https://app.9tofit.nl

# Meta Pixel (Fase 2 — ads tracking).
# LEEG laten = volledig uit: geen pixel, geen cookies, geen consent-banner.
# Vul in met je Pixel/Dataset-id (een getal) uit Meta Events Manager om aan te zetten.
NEXT_PUBLIC_META_PIXEL_ID=

# Calendly booking-URL (laag 4). Default = de strategiecall-link.
# Overschrijf alleen als je een andere event-URL wilt gebruiken.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/max-9tofit/performance-strategy-call
